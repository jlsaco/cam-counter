# ───── Binarios pesados / regenerables (se quedan en disco, fuera de git) ─────

# Sysroot amd64 + JRE x86-64 para box64 (~175 MB) — se reconstruye (ver README)
v1/rtsp-enable/x64root/

# SDK nativo Hikvision x86-64 (~26 MB, binarios de terceros)
v1/rtsp-enable/lib/

# Artefactos descargados / construidos (regenerables con gradle / apt / curl)
v1/rtsp-enable/*.jar
v1/rtsp-enable/jre-x64.tar.gz
v1/rtsp-enable/*.deb
v1/rtsp-enable/.build.gradle/
v1/rtsp-enable/.gradle/

# ───── Credenciales (NUNCA en git) ─────
# Código de verificación de la cámara (contraseña de admin para SDK/RTSP).
# Se inyecta por entorno $CAM_PASS o por este fichero local; jamás versionado.
v1/rtsp-enable/CAM_PASS
v1/rtsp-enable/secrets/

# ───── Runtime / estado / logs ─────
v1/rtsp-enable/sdklog/
v1/rtsp-enable/CAM_IP
v1/rtsp-enable/RTSP_URL
v1/rtsp-enable/*.flag
v1/rtsp-enable/*.log
*.log

# ───── Python ─────
__pycache__/
*.pyc
*.egg-info/
.eggs/
build/
.pytest_cache/
.ruff_cache/
# Entornos virtuales locales (la verificación usa un venv efímero).
.venv/
venv/
# SQLite local del borde/API (datos de runtime; jamás se commitea).
*.db
*.db-wal
*.db-shm

# ───── Terraform ─────
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
crash.log
# Planes binarios guardados (-out): los genera el runner al aplicar; jamás se commitean.
tfplan*
*.tfplan

# ───── Node / Vite ─────
node_modules/
# Artefactos de runtime de Playwright (E2E): reportes y resultados.
test-results/
playwright-report/
.last-run.json
dist/
.vite/
*.local

# ───── Misc ─────
*.tmp

# Configuracion local con secretos (RTSP). Nunca versionar.
/.env

# Pids/logs de los procesos lanzados por el Makefile (make up).
/.run/

# Clips de video generados en runtime (media local; se sube a S3).
/v1/clips/

# ───── Identidad IoT por-device (NUNCA en git) ─────
# Salida de scripts/provision-device.sh: certs, llave privada, CSR, .env y bundle de
# cada device. Contienen la LLAVE PRIVADA del Pi y rutas a secretos; jamás se versionan.
/provisioning/
# Defensa en profundidad por si OUT_DIR apuntara a otra ruta del repo:
*.cert.pem
*.private.key
*.csr
AmazonRootCA1.pem
device-bundle.tar.gz
