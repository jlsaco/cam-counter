# === cam-counter — consola de flota (web/dashboard) — plantilla de config ===
#   cp .env.example .env.local   &&   rellena con los outputs de Terraform.
# El .env.local real NO se versiona (.gitignore). NINGÚN secreto AWS aquí:
# todos los valores son IDENTIFICADORES PÚBLICOS (no credenciales).
#
# Las variables son NEXT_PUBLIC_* porque el frontend las consume en el navegador
# (Next.js solo inlina al cliente las que empiezan por NEXT_PUBLIC_).

# Base de la API de WP11 (fleet-api tras el authorizer JWT Cognito de API Gateway).
# FQDN del HTTP API v2, sin barra final. Ej.: https://abc123.execute-api.us-east-1.amazonaws.com
NEXT_PUBLIC_API_BASE_URL=https://CHANGEME.execute-api.us-east-1.amazonaws.com

# Región AWS (us-east-1 por convención del proyecto).
NEXT_PUBLIC_AWS_REGION=us-east-1

# Cognito — outputs Terraform del módulo cognito (WP10):
#   terraform -chdir=terraform/environments/prod output cognito_user_pool_id
#   terraform -chdir=terraform/environments/prod output cognito_web_client_id
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_CHANGEME
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=CHANGEME

# Hosted UI domain (PREFIJO) para el login OAuth/PKCE real (se valida end-to-end en WP13).
# Para desarrollo local NO es necesario: el Authenticator usa login usuario/clave (SRP).
NEXT_PUBLIC_COGNITO_HOSTED_UI_DOMAIN=
# URLs de callback/logout OAuth (deben coincidir con las del app client de Cognito en WP13).
NEXT_PUBLIC_COGNITO_REDIRECT_SIGN_IN=http://localhost:3000/
NEXT_PUBLIC_COGNITO_REDIRECT_SIGN_OUT=http://localhost:3000/login
