# === cam-counter — consola de flota (web/dashboard) — plantilla de configuración ===
#   cp .env.example .env.local   &&   rellena con los outputs de Terraform (WP10/WP11).
# El .env.local real NO se versiona (.gitignore). Todo es CONFIG PÚBLICA (`NEXT_PUBLIC_*`):
# IDs de Cognito y endpoint de la API. NINGÚN secreto AWS vive aquí (la API valida el JWT).

# --- API de flota (WP11: HTTP API + authorizer JWT Cognito). SIN barra final. ---
NEXT_PUBLIC_API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# --- Cognito (WP10: módulo `cognito`). Outputs: user_pool_id, web_client_id, ... ---
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_WEB_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: federación a credenciales AWS de corta vida (output identity_pool_id).
# NEXT_PUBLIC_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Opcional: Hosted UI (OAuth/PKCE). Prefijo del dominio (output hosted_ui_domain) y callbacks.
# El login PKCE end-to-end con dominio Amplify se valida en WP13 (callback válido).
# NEXT_PUBLIC_COGNITO_HOSTED_UI_DOMAIN=cam-counter-fleet-950639281773
# NEXT_PUBLIC_COGNITO_REDIRECT_SIGN_IN=http://localhost:3000/login
# NEXT_PUBLIC_COGNITO_REDIRECT_SIGN_OUT=http://localhost:3000/login
