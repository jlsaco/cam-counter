# === cam-counter — plantilla de configuracion (copiala a .env y rellena) ===
#   cp .env.example .env   &&   edita CAMCOUNTER_RTSP_URL con el password real
# El .env real NO se versiona (esta en .gitignore): contiene el secreto RTSP.

# Camara EZVIZ por RTSP. Password = codigo de verificacion de la pegatina.
# Formato: rtsp://admin:<PASSWORD>@<IP_CAMARA>:554/Streaming/Channels/101
CAMCOUNTER_RTSP_URL=rtsp://admin:CHANGEME@192.168.1.8:554/Streaming/Channels/101

CAMCOUNTER_SITE_ID=casa
CAMCOUNTER_DEVICE_ID=rpi-cam
CAMCOUNTER_CAMERA_COUNT=1

# Ruta ABSOLUTA del SQLite del borde (rellena con la ruta de tu clon + /v1/cam-counter.db)
CAMCOUNTER_DB_PATH=/home/pi/Documents/hailo-ezviz-personas/v1/cam-counter.db

CAMCOUNTER_HOST=0.0.0.0
CAMCOUNTER_PORT=8088
CAMCOUNTER_FRAME_INTERVAL=0.2
CAMCOUNTER_API_TOKEN=

CAMCOUNTER_HEALTHZ_HOST=0.0.0.0
CAMCOUNTER_HEALTHZ_PORT=8081

CAMCOUNTER_FAKE_SOURCE=0

# --- Sincronizacion a la nube (edge -> AWS DynamoDB/S3) ---
CAMCOUNTER_SYNC_ENABLED=1
CAMCOUNTER_AWS_REGION=us-east-1
CAMCOUNTER_SYNC_INTERVAL_S=10
# CAMCOUNTER_EDGE_ROLE_ARN=arn:aws:iam::<acct>:role/cam-counter-edge-...

# --- Clips de video por evento (MP4/GIF a S3, enlazados a DynamoDB) ---
CAMCOUNTER_CLIPS_ENABLED=1
CAMCOUNTER_CLIP_GRACE_S=15

# --- Identidad IoT del device (lo genera scripts/provision-device.sh; ver docs/provisioning.md) ---
# Estas claves las escribe el bundle .env por-device. Aqui solo se documentan (sin secretos).
# El transporte de sync por defecto es 'direct'; 'iot' (MQTT) se habilita en WPs posteriores.
CAMCOUNTER_SYNC_TRANSPORT=direct
# CAMCOUNTER_THING_NAME=cam-counter-<site_id>-<device_id>
# CAMCOUNTER_MQTT_CLIENT_ID=cam-counter-<site_id>-<device_id>
# CAMCOUNTER_IOT_ENDPOINT=<account>-ats.iot.us-east-1.amazonaws.com
# CAMCOUNTER_ROLE_ALIAS=cam-counter-edge-s3-role-alias
# CAMCOUNTER_IOT_CERT_PATH=/etc/cam-counter/certs/device.cert.pem
# CAMCOUNTER_IOT_PRIVATE_KEY_PATH=/etc/cam-counter/certs/device.private.key
# CAMCOUNTER_IOT_ROOT_CA_PATH=/etc/cam-counter/certs/AmazonRootCA1.pem
# CAMCOUNTER_TOPIC_EVENTS=cam-counter/<device_id>/events/crossing
# CAMCOUNTER_TOPIC_STATUS=cam-counter/<device_id>/status
# CAMCOUNTER_TOPIC_TELEMETRY=cam-counter/<device_id>/telemetry
# CAMCOUNTER_TOPIC_CMD=cam-counter/<device_id>/cmd
