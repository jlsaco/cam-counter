# === cam-counter — plantilla de configuracion (copiala a .env y rellena) ===
#   cp .env.example .env   &&   edita CAMCOUNTER_RTSP_URL con el password real
# El .env real NO se versiona (esta en .gitignore): contiene el secreto RTSP.
#
# SOLO claves CAMCOUNTER_* (canon de naming). NUNCA credenciales AWS estaticas:
# el modo iot usa el certificado mTLS del device (volumen certs montado :ro). En
# Docker este MISMO fichero (a) se pasa al contenedor (env_file) y (b) lo lee
# `docker compose` para interpolar tag de imagen / GID del Hailo / ruta de certs.

# --- Docker (WP17): interpolacion de docker-compose.yml ---
# Tag de la imagen edge. Convencion: <version>-hrt<HAILORT>-arm64 (el sufijo hrt
# DEBE casar con el driver hailo_pci del host: modinfo hailo_pci | grep ^version).
CAMCOUNTER_IMAGE_TAG=dev-hrt4.23.0-arm64
# GID NUMERICO dueño de /dev/hailo0 en el HOST:  stat -c '%g' /dev/hailo0
CAMCOUNTER_HAILO_GID=0
# Directorio del HOST con el material mTLS del device (se monta :ro en el edge).
# Lo genera scripts/provision-device.sh; la LLAVE privada debe quedar 0600.
CAMCOUNTER_CERTS_DIR=./certs

# Camara EZVIZ por RTSP. Password = codigo de verificacion de la pegatina.
# Formato: rtsp://admin:<PASSWORD>@<IP_CAMARA>:554/Streaming/Channels/101
CAMCOUNTER_RTSP_URL=rtsp://admin:CHANGEME@192.168.1.8:554/Streaming/Channels/101

CAMCOUNTER_SITE_ID=casa
CAMCOUNTER_DEVICE_ID=rpi-cam
CAMCOUNTER_CAMERA_COUNT=1

# Ruta ABSOLUTA del SQLite del borde. En Docker es el volumen `cam-counter-db`
# (edge rw, api ro); en runtime nativo (plan B) es la misma ruta canonica systemd.
CAMCOUNTER_DB_PATH=/var/lib/cam-counter/cam-counter.db

CAMCOUNTER_HOST=0.0.0.0
CAMCOUNTER_PORT=8088
CAMCOUNTER_FRAME_INTERVAL=0.2
CAMCOUNTER_API_TOKEN=

CAMCOUNTER_HEALTHZ_HOST=0.0.0.0
CAMCOUNTER_HEALTHZ_PORT=8081

CAMCOUNTER_FAKE_SOURCE=0

# --- Sincronizacion a la nube (edge -> AWS) ---
CAMCOUNTER_SYNC_ENABLED=1
CAMCOUNTER_AWS_REGION=us-east-1
CAMCOUNTER_SYNC_INTERVAL_S=10

# Transporte del sync del proceso de borde (lo elige cam_counter_edge.sync_dispatch):
#   iot    = publica el CrossingEvent por MQTT a AWS IoT Core con el certificado mTLS
#            del device; los clips suben via IoT Credential Provider (role alias). El
#            proceso de borde NO usa credenciales AWS DIRECTAS. <-- estado tras WP16.
#   direct = camino historico (boto3 directo a DynamoDB/S3 con el rol STS per-Pi).
# El corte es REVERSIBLE: para volver al camino directo, cambia a 'direct' y reinicia
# el sync (no reinstala nada). Detalle en docs/edge-direct-path-cutover.md.
CAMCOUNTER_SYNC_TRANSPORT=iot

# --- Identidad IoT Core del device (modo iot). La escribe scripts/provision-device.sh
#     en el .env del bundle; copia aqui esos valores. SIN credenciales AWS estaticas.
#     El modo iot ES FAIL-CLOSED: sin thing-name/endpoint/cert el sync aborta al boot. ---
# CAMCOUNTER_IOT_THING_NAME=cam-counter-casa-rpi-cam
# CAMCOUNTER_IOT_ENDPOINT=<iot-ats-endpoint>.iot.us-east-1.amazonaws.com
# CAMCOUNTER_IOT_CERT_PATH=/etc/cam-counter/certs/device.cert.pem
# CAMCOUNTER_IOT_KEY_PATH=/etc/cam-counter/certs/device.private.key
# CAMCOUNTER_IOT_ROOT_CA_PATH=/etc/cam-counter/certs/AmazonRootCA1.pem
# CAMCOUNTER_ROLE_ALIAS=cam-counter-edge-s3-role-alias
# CAMCOUNTER_IOT_CRED_ENDPOINT=<iot-credential-provider-endpoint>.credentials.iot.us-east-1.amazonaws.com

# Solo modo direct: rol STS per-Pi a asumir (vacio = cadena de creds por defecto).
# CAMCOUNTER_EDGE_ROLE_ARN=arn:aws:iam::<acct>:role/cam-counter-edge-...

# --- Clips de video por evento (MP4/GIF a S3, enlazados a DynamoDB) ---
CAMCOUNTER_CLIPS_ENABLED=1
CAMCOUNTER_CLIP_GRACE_S=15
