# === cam-counter — plantilla de configuracion (copiala a .env y rellena) ===
#   cp .env.example .env   &&   edita CAMCOUNTER_RTSP_URL con el password real
# El .env real NO se versiona (esta en .gitignore): contiene el secreto RTSP.

# Camara EZVIZ por RTSP. Password = codigo de verificacion de la pegatina.
# Formato: rtsp://admin:<PASSWORD>@<IP_CAMARA>:554/Streaming/Channels/101
CAMCOUNTER_RTSP_URL=rtsp://admin:CHANGEME@192.168.1.8:554/Streaming/Channels/101

CAMCOUNTER_SITE_ID=casa
CAMCOUNTER_DEVICE_ID=rpi-cam
CAMCOUNTER_CAMERA_COUNT=1

# Ruta ABSOLUTA del SQLite del borde (rellena con la ruta de tu clon + /v1/cam-counter.db)
CAMCOUNTER_DB_PATH=/home/pi/Documents/hailo-ezviz-personas/v1/cam-counter.db

CAMCOUNTER_HOST=0.0.0.0
CAMCOUNTER_PORT=8088
CAMCOUNTER_FRAME_INTERVAL=0.2
CAMCOUNTER_API_TOKEN=

CAMCOUNTER_HEALTHZ_HOST=0.0.0.0
CAMCOUNTER_HEALTHZ_PORT=8081

CAMCOUNTER_FAKE_SOURCE=0
