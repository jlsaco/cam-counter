{
  "components": {
    "schemas": {
      "Camera": {
        "additionalProperties": false,
        "description": "Descriptor de una cámara lógica del Pi.",
        "properties": {
          "camera_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Camera Id",
            "type": "string"
          },
          "config_version": {
            "minimum": 0.0,
            "title": "Config Version",
            "type": "integer"
          },
          "device_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Device Id",
            "type": "string"
          },
          "frames_processed": {
            "minimum": 0.0,
            "title": "Frames Processed",
            "type": "integer"
          },
          "has_config": {
            "title": "Has Config",
            "type": "boolean"
          },
          "online": {
            "title": "Online",
            "type": "boolean"
          },
          "site_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Site Id",
            "type": "string"
          }
        },
        "required": [
          "camera_id",
          "site_id",
          "device_id",
          "config_version",
          "has_config",
          "frames_processed",
          "online"
        ],
        "title": "Camera",
        "type": "object"
      },
      "CameraHealth": {
        "additionalProperties": false,
        "description": "Salud de PRODUCTO por cámara (criterio para el gate de OTA).",
        "properties": {
          "camera_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Camera Id",
            "type": "string"
          },
          "config_version": {
            "minimum": 0.0,
            "title": "Config Version",
            "type": "integer"
          },
          "frames_processed": {
            "minimum": 0.0,
            "title": "Frames Processed",
            "type": "integer"
          },
          "hailo_inference_ok": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Hailo Inference Ok"
          },
          "last_inference_ts": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Inference Ts"
          }
        },
        "required": [
          "camera_id",
          "frames_processed",
          "last_inference_ts",
          "hailo_inference_ok",
          "config_version"
        ],
        "title": "CameraHealth",
        "type": "object"
      },
      "CounterDay": {
        "additionalProperties": false,
        "description": "Conteo de una cámara para un día UTC y un sentido de cable.",
        "properties": {
          "count": {
            "minimum": 0.0,
            "title": "Count",
            "type": "integer"
          },
          "day_utc": {
            "title": "Day Utc",
            "type": "string"
          },
          "direction": {
            "enum": [
              "in",
              "out"
            ],
            "title": "Direction",
            "type": "string"
          }
        },
        "required": [
          "day_utc",
          "direction",
          "count"
        ],
        "title": "CounterDay",
        "type": "object"
      },
      "Counters": {
        "additionalProperties": false,
        "description": "Contadores agregados de una cámara (totales + desglose por día).",
        "properties": {
          "camera_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Camera Id",
            "type": "string"
          },
          "days": {
            "items": {
              "$ref": "#/components/schemas/CounterDay"
            },
            "title": "Days",
            "type": "array"
          },
          "in_count": {
            "minimum": 0.0,
            "title": "In Count",
            "type": "integer"
          },
          "net": {
            "title": "Net",
            "type": "integer"
          },
          "out_count": {
            "minimum": 0.0,
            "title": "Out Count",
            "type": "integer"
          }
        },
        "required": [
          "camera_id",
          "in_count",
          "out_count",
          "net",
          "days"
        ],
        "title": "Counters",
        "type": "object"
      },
      "CrossingEvent": {
        "additionalProperties": false,
        "description": "Evento de cruce de línea — espejo de ``contracts/crossing_event.schema.json``.",
        "properties": {
          "camera_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Camera Id",
            "type": "string"
          },
          "clip_key": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Clip Key"
          },
          "clip_status": {
            "anyOf": [
              {
                "enum": [
                  "pending",
                  "uploading",
                  "uploaded",
                  "failed"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Clip Status"
          },
          "confidence": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence"
          },
          "created_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created At"
          },
          "crossing_seq": {
            "minimum": 0.0,
            "title": "Crossing Seq",
            "type": "integer"
          },
          "device_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Device Id",
            "type": "string"
          },
          "direction": {
            "enum": [
              "in",
              "out"
            ],
            "title": "Direction",
            "type": "string"
          },
          "event_id": {
            "pattern": "^[0-9a-f]{40}$",
            "title": "Event Id",
            "type": "string"
          },
          "label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Label"
          },
          "line_version": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Line Version"
          },
          "negative_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Negative Label"
          },
          "positive_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Positive Label"
          },
          "schema_version": {
            "default": 1,
            "title": "Schema Version",
            "type": "integer"
          },
          "site_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Site Id",
            "type": "string"
          },
          "synced": {
            "default": 0,
            "title": "Synced",
            "type": "integer"
          },
          "track_id": {
            "title": "Track Id",
            "type": "string"
          },
          "ts_event_iso": {
            "title": "Ts Event Iso",
            "type": "string"
          },
          "ts_event_ms": {
            "title": "Ts Event Ms",
            "type": "integer"
          }
        },
        "required": [
          "event_id",
          "site_id",
          "device_id",
          "camera_id",
          "track_id",
          "crossing_seq",
          "direction",
          "ts_event_ms",
          "ts_event_iso"
        ],
        "title": "CrossingEvent",
        "type": "object"
      },
      "DeviceInfo": {
        "additionalProperties": false,
        "description": "Identidad y versión del dispositivo (``/api/device``).",
        "properties": {
          "app_version": {
            "title": "App Version",
            "type": "string"
          },
          "camera_ids": {
            "items": {
              "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
              "type": "string"
            },
            "title": "Camera Ids",
            "type": "array"
          },
          "db_schema_version": {
            "title": "Db Schema Version",
            "type": "integer"
          },
          "device_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Device Id",
            "type": "string"
          },
          "fake_source": {
            "title": "Fake Source",
            "type": "boolean"
          },
          "git_sha": {
            "title": "Git Sha",
            "type": "string"
          },
          "site_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Site Id",
            "type": "string"
          }
        },
        "required": [
          "device_id",
          "site_id",
          "app_version",
          "git_sha",
          "camera_ids",
          "db_schema_version",
          "fake_source"
        ],
        "title": "DeviceInfo",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "Health": {
        "additionalProperties": false,
        "description": "Salud de PRODUCTO del proceso (no mera liveness).\n\nUn ``200`` con ``frames_processed=0`` en todas las cámaras es DISTINGUIBLE de\nsalud real: ``frames_flowing`` es ``False`` cuando ninguna cámara ha procesado\nframes todavía.",
        "properties": {
          "app_version": {
            "title": "App Version",
            "type": "string"
          },
          "cameras": {
            "items": {
              "$ref": "#/components/schemas/CameraHealth"
            },
            "title": "Cameras",
            "type": "array"
          },
          "db_schema_version": {
            "title": "Db Schema Version",
            "type": "integer"
          },
          "fake_source": {
            "title": "Fake Source",
            "type": "boolean"
          },
          "frames_flowing": {
            "title": "Frames Flowing",
            "type": "boolean"
          },
          "status": {
            "enum": [
              "ok",
              "degraded"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "app_version",
          "db_schema_version",
          "fake_source",
          "frames_flowing",
          "cameras"
        ],
        "title": "Health",
        "type": "object"
      },
      "LineConfig": {
        "additionalProperties": false,
        "description": "Config de la línea por cámara — espejo de ``contracts/line_config.schema.json``.",
        "properties": {
          "camera_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Camera Id",
            "type": "string"
          },
          "config_version": {
            "minimum": 0.0,
            "title": "Config Version",
            "type": "integer"
          },
          "device_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Device Id",
            "type": "string"
          },
          "line": {
            "$ref": "#/components/schemas/LineGeom"
          },
          "negative_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Negative Label"
          },
          "positive_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Positive Label"
          },
          "positive_side": {
            "enum": [
              -1,
              1
            ],
            "title": "Positive Side",
            "type": "integer"
          },
          "schema_version": {
            "default": 1,
            "title": "Schema Version",
            "type": "integer"
          },
          "site_id": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Site Id",
            "type": "string"
          },
          "updated_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Updated At"
          }
        },
        "required": [
          "site_id",
          "device_id",
          "camera_id",
          "config_version",
          "line",
          "positive_side"
        ],
        "title": "LineConfig",
        "type": "object"
      },
      "LineConfigUpdate": {
        "additionalProperties": false,
        "description": "Cuerpo del ``PUT`` de config: geometría/labels/sentido + CAS de versión.\n\n``site_id``/``device_id``/``camera_id`` NO los aporta el cliente: los resuelve\nel servidor desde la cámara (evita incoherencias). ``expected_config_version``\nes el ``config_version`` que el cliente cree vigente; si está desactualizado el\nPUT devuelve ``409`` (concurrencia optimista, compare-and-set).",
        "properties": {
          "expected_config_version": {
            "minimum": 0.0,
            "title": "Expected Config Version",
            "type": "integer"
          },
          "line": {
            "$ref": "#/components/schemas/LineGeom"
          },
          "negative_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Negative Label"
          },
          "positive_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Positive Label"
          },
          "positive_side": {
            "enum": [
              -1,
              1
            ],
            "title": "Positive Side",
            "type": "integer"
          }
        },
        "required": [
          "line",
          "positive_side",
          "expected_config_version"
        ],
        "title": "LineConfigUpdate",
        "type": "object"
      },
      "LineGeom": {
        "additionalProperties": false,
        "description": "Línea-umbral definida por dos endpoints normalizados ``a`` y ``b``.",
        "properties": {
          "a": {
            "$ref": "#/components/schemas/Point2D"
          },
          "b": {
            "$ref": "#/components/schemas/Point2D"
          }
        },
        "required": [
          "a",
          "b"
        ],
        "title": "LineGeom",
        "type": "object"
      },
      "Point2D": {
        "additionalProperties": false,
        "description": "Punto normalizado 0..1 (origen arriba-izquierda).",
        "properties": {
          "x": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "X",
            "type": "number"
          },
          "y": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Y",
            "type": "number"
          }
        },
        "required": [
          "x",
          "y"
        ],
        "title": "Point2D",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "cam-counter local API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/cameras": {
      "get": {
        "operationId": "list_cameras_api_cameras_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/Camera"
                  },
                  "title": "Response List Cameras Api Cameras Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Cameras",
        "tags": [
          "cameras"
        ]
      }
    },
    "/api/cameras/{camera_id}": {
      "get": {
        "operationId": "get_camera_api_cameras__camera_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "camera_id",
            "required": true,
            "schema": {
              "title": "Camera Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Camera"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Camera",
        "tags": [
          "cameras"
        ]
      }
    },
